{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OttoServ Enrich Lead Contact Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "lead_id",
    "idempotency_key",
    "status",
    "actor",
    "validated_at",
    "source_urls",
    "contact_path",
    "confidence",
    "external_outreach_taken"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "task_id": { "type": "string" },
    "lead_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "status": { "enum": ["completed", "blocked", "not_found", "needs_manual_review"] },
    "actor": { "type": "string", "minLength": 1 },
    "validated_at": { "type": "string", "format": "date-time" },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "format": "uri" }
    },
    "contact_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phone", "email"],
      "properties": {
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_summary": { "type": "string" },
    "provider_reference": { "type": "string" },
    "block_reason": { "type": "string" },
    "external_outreach_taken": { "const": false }
  }
}

# Hermes Phase 0 environment template.
# Install to /etc/hermes/phase0.env, root-owned, chmod 0600.
# NEVER commit real Telegram tokens or IDs.

HERMES_STATE_ROOT=/var/lib/hermes/revenue-engine
HERMES_TASKS_DIR=/var/lib/hermes/revenue-engine/tasks
HERMES_APPROVALS_DIR=/var/lib/hermes/revenue-engine/approvals
HERMES_PENDING_DIR=/var/lib/hermes/revenue-engine/pending-operations
HERMES_NOTIFY_STATE_DIR=/var/lib/hermes/revenue-engine/notify-state
HERMES_NOTIFY_QUEUE_DIR=/var/lib/hermes/revenue-engine/notify-queue
HERMES_PENDING_EXPIRY_MIN=30
MODE=dry
HERMES_ALLOWED_TELEGRAM_USER_IDS=
HERMES_ALLOWED_CHAT_IDS=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
HERMES_ALERT_COOLDOWN_MIN=30
WATCHDOG_AUTOREPAIR=true
# HERMES_EMAIL_MODE=no_send
# HERMES_CALL_MODE=no_dial
